{
  "name": "opencode-agent-skills-md",
  "version": "1.5.6",
  "description": "OpenCode plugin for agent skills — single-package Bun layout.",
  "type": "module",
  "main": "dist/src/plugin.js",
  "types": "dist/src/plugin.d.ts",
  "bin": {
    "oaskills": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/src/plugin.d.ts",
      "import": "./dist/src/plugin.js"
    }
  },
  "oc-plugin": [
    "server"
  ],
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsc && bun run build:cli",
    "build:cli": "bun run scripts/build-cli.ts",
    "clean": "rm -rf dist",
    "install-local": "mkdir -p .opencode/plugins && printf 'import { SkillsPlugin } from \"../../src/plugin.ts\";\n' > .opencode/plugins/skills.ts",
    "status": "ls -la .opencode/plugins/skills.ts 2>/dev/null || echo Not installed",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.18.1"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/node": "^26.1.1",
    "bun-types": "^1.3.14",
    "typescript": "^7.0.2"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MetalbolicX/opencode-agent-skills-md.git"
  }
}
