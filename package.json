{
  "name": "opencode-agent-skills-md",
  "version": "1.4.0",
  "description": "OpenCode plugin for agent skills — single-package Bun layout.",
  "type": "module",
  "main": "src/plugin.ts",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "install-local": "mkdir -p .opencode/plugins && echo 'export { SkillsPlugin } from \"./src/plugin.ts\";' > .opencode/plugins/skills.js",
    "status": "ls -la .opencode/plugins/skills.js 2>/dev/null || echo Not installed"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@opencode-ai/plugin": "^1.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.0",
    "@types/node": "^20.0.0",
    "bun-types": "^1.0.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "onnxruntime-node": "1.20.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MetalbolicX/opencode-agent-skills-md.git"
  }
}
