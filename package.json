{
    "name": "opencode-agent-skills",
    "version": "0.7.0",
    "description": "A dynamic skills plugin for OpenCode that provides tools for loading and using reusable AI agent skills.",
    "author": "Josh Thomas <josh@joshthomas.dev>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/joshuadavidthomas/opencode-agent-skills.git"
    },
    "keywords": [
        "opencode",
        "plugin",
        "skills",
        "agent",
        "ai"
    ],
    "main": "dist/plugin.mjs",
    "type": "module",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "rolldown -c",
        "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
        "test:unit": "node --import tsx --test src/*.test.ts",
        "test:integration": "node --import tsx --test tests/integration/*.test.ts",
        "test:e2e": "node --import tsx --test tests/e2e/*.test.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@opencode-ai/plugin": "^1.15.11",
        "yaml": "^2.9.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/node": "^25.9.1",
        "rolldown": "^1.0.3",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
